# 复制为 .env 后填写真实 API key；.env 已加入 .gitignore。
QA_USE_LLM_READER=1
QA_LLM_API_KEY=your_sophnet_api_key
QA_LLM_BASE_URL=https://www.sophnet.com/api/open-apis
QA_LLM_MODEL=DeepSeek-v3

# SophNet Embedding 会复用 QA_LLM_API_KEY；project_id 和 easyllm_id 需要在 SophNet 控制台创建 embedding 服务后填写。
QA_EMBEDDING_PROVIDER=sophnet
QA_EMBEDDING_BASE_URL=https://www.sophnet.com/api/open-apis
QA_EMBEDDING_PROJECT_ID=your_sophnet_project_id
QA_EMBEDDING_EASYLLM_ID=your_embedding_easyllm_id
QA_EMBEDDING_MODEL=your_embedding_easyllm_id
QA_EMBEDDING_DIMENSIONS=1024

# 联网搜索需要额外搜索服务 key；SophNet LLM key 不能直接当搜索 key 使用。
QA_ENABLE_WEB_SEARCH=0
